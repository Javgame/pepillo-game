<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Pepillo — Pixel Art (Single File)</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
           display:flex; justify-content:center; background:#0f1320; margin:0; padding:20px; }
    #wrap { width:min(1000px,98vw); background:#fff; border-radius:14px; padding:12px 14px 16px; }
    h1 { margin:6px 0 4px; }
    .subtitle { color:#333; margin:0 0 6px; }
    canvas { width:100%; height:auto; border:6px solid #333; border-radius:12px; background:linear-gradient(#7ed1ff,#c9f0ff); }
    #hint { margin:8px 0 0; font-weight:600; }
  </style>
</head>
<body>
  <div id="wrap">
    <h1>Pepillo — Pixel Art Edition</h1>
    <p class="subtitle">Sedona, Arizona · Busca la bebida energética de la juventud eterna</p>
    <canvas id="game" width="1000" height="560"></canvas>
    <div id="hint">Controles: ← → moverse · ↑/Barra saltar · R reiniciar</div>
    <p style="margin:10px 0 0;font-size:13px;color:#555">¿Quieres descansar? Juega al <a href="cachito.html" style="color:#1976d2;font-weight:600">&#127922; Cachito</a></p>
  </div>
  <script>
    const cvs = document.getElementById('game'); const ctx = cvs.getContext('2d');
    const W=cvs.width, H=cvs.height;
    let keys={}; addEventListener('keydown',e=>{keys[e.key]=true; if(e.key==='r'||e.key==='R') init();});
    addEventListener('keyup',e=>keys[e.key]=false);

    // Sprite pixel art embebido en data URI (no hace falta carpeta assets)
    const sprite = new Image(); sprite.src =
'data:image/png;base64,iVBORw0K...<recortado por brevedad>...SuQmCC';

    let p, plats, obs, cans, goal, cam, score, over, t, won;
    function resetLevel(){
      plats=[
        {x:0,y:H-60,w:4000,h:80},
        {x:240,y:H-140,w:120,h:16},{x:420,y:H-200,w:140,h:16},
        {x:650,y:H-160,w:150,h:16},{x:880,y:H-220,w:160,h:16},
        {x:1150,y:H-180,w:160,h:16},{x:1420,y:H-240,w:160,h:16},
        {x:1710,y:H-200,w:160,h:16},{x:1980,y:H-260,w:160,h:16},
        {x:2260,y:H-220,w:160,h:16},{x:2540,y:H-180,w:160,h:16},
        {x:2820,y:H-220,w:160,h:16},
      ];
      obs=[
        {x:360,y:H-90,w:26,h:30},{x:770,y:H-90,w:26,h:44},
        {x:1300,y:H-90,w:26,h:36},{x:1890,y:H-90,w:26,h:42},
        {x:2470,y:H-90,w:26,h:38},{x:3110,y:H-90,w:26,h:40},
      ];
      cans=[
        {x:270,y:H-180,c:false},{x:460,y:H-240,c:false},{x:690,y:H-200,c:false},
        {x:920,y:H-260,c:false},{x:1190,y:H-220,c:false},{x:1460,y:H-280,c:false},
        {x:1750,y:H-240,c:false},{x:2020,y:H-300,c:false},{x:2300,y:H-260,c:false},
      ];
      goal={x:3350,y:H-140,w:48,h:70};
    }
    function init(){
      p={x:60,y:H-140,w:64,h:80,vx:0,vy:0,on:false};
      cam=0; score=0; over=false; won=false; t=0; resetLevel(); loop();
    }
    const G=0.9, F=0.88, MAX=6.2, JUMP=15;
    function loop(){ update(); render(); if(!over) requestAnimationFrame(loop); }
    function update(){
      t++;
      if(keys['ArrowLeft']||keys['a']) p.vx-=0.8;
      if(keys['ArrowRight']||keys['d']) p.vx+=0.8;
      if((keys['ArrowUp']||keys[' '])&&p.on){ p.vy=-JUMP; p.on=false; }
      p.vy+=G; p.x+=p.vx; p.y+=p.vy; p.vx*=F; if(Math.abs(p.vx)>MAX) p.vx=p.vx>0?MAX:-MAX;
      p.on=false;
      for(const r of plats) if(overlap(p,r)) if(p.vy>0 && p.y+p.h-r.y<24){ p.y=r.y-p.h; p.vy=0; p.on=true; }
      for(const o of obs) if(overlap(p,o)){ over=true; msg('¡Auch! Obstáculo en Sedona. R para reiniciar.'); }
      for(const c of cans) if(!c.c && pointIn(center(p), {x:c.x-10,y:c.y-28,w:20,h:36})){ c.c=true; score++; msg('¡Energía! '+score+'/'+cans.length); }
      if(score>=6 && overlap(p,goal)){ won=true; over=true; msg('¡Pepillo consiguió la bebida!'); }
      if(p.y>H+200){ over=true; msg('Pepillo cayó. R para reiniciar.'); }
      cam=Math.max(0, p.x-220);
    }
    function msg(s){ document.title='Pepillo — '+s; }
    function render(){
      ctx.clearRect(0,0,W,H);
      sky(); rocks(cam*0.2,90,'#f07a4b'); rocks(cam*0.5,140,'#c75a36');
      ctx.fillStyle='#a64d2a'; ctx.fillRect(-cam,H-60,4200,80);
      for(const r of plats){ ctx.fillStyle='#d07141'; ctx.fillRect(r.x-cam,r.y,r.w,r.h); ctx.fillStyle='#f09b66'; ctx.fillRect(r.x-cam,r.y,r.w,5); }
      for(const o of obs){ ctx.fillStyle='#2e6b35'; ctx.fillRect(o.x-cam,o.y,o.w,o.h); ctx.fillStyle='#1d4e22'; ctx.fillRect(o.x-cam,o.y,o.w,6); }
      for(const c of cans) if(!c.c) can(c.x-cam,c.y);
      goalDraw(goal.x-cam,goal.y,won);
      const bob = Math.sin(t/6)*(p.on?2:4);
      const px = Math.round(p.x-cam), py=Math.round(p.y+bob);
      ctx.imageSmoothingEnabled=false; // pixel art nítido
      ctx.drawImage(sprite, px, py, p.w, p.h);
      ctx.fillStyle='#222'; ctx.font='18px -apple-system,Segoe UI,Roboto,sans-serif';
      ctx.fillText('Botellas: '+score+'/'+cans.length+' — Sedona, AZ', 12, 26);
      if(over){
        ctx.fillStyle='rgba(0,0,0,.5)'; ctx.fillRect(0,0,W,H);
        ctx.fillStyle='#fff'; ctx.font='28px -apple-system,Segoe UI,Roboto,sans-serif';
        ctx.fillText(won?'¡Nivel completado!':'Game Over', W/2-110, H/2-10);
        ctx.font='18px -apple-system,Segoe UI,Roboto,sans-serif';
        ctx.fillText('Pulsa R para reiniciar', W/2-95, H/2+20);
      }
    }
    // helpers
    function overlap(a,b){return a.x+a.w>b.x && a.x<b.x+b.w && a.y+a.h>b.y && a.y<b.y+b.h;}
    function center(r){return {x:r.x+r.w/2, y:r.y+r.h/2};}
    function pointIn(pt,r){return pt.x>=r.x&&pt.x<=r.x+r.w&&pt.y>=r.y&&pt.y<=r.y+r.h;}
    function can(x,y){ ctx.fillStyle='#ffd400'; ctx.fillRect(x-8,y-24,16,28);
      ctx.fillStyle='#fff'; ctx.fillRect(x-6,y-22,12,6); ctx.fillStyle='#333'; ctx.fillRect(x-8,y-24,16,3); }
    function goalDraw(x,y,open){ ctx.fillStyle=open?'#4caf50':'#1976d2'; ctx.fillRect(x,y,48,50);
      ctx.fillStyle='#eee'; ctx.fillRect(x+6,y+6,36,28); ctx.fillStyle='#333'; ctx.fillRect(x+20,y-10,8,10); ctx.fillText('META', x-2,y+64); }
    function sky(){ ctx.fillStyle='rgba(255,255,255,.9)';
      for(let i=0;i<6;i++){const cx=(i*260 - cam*0.3)%(W+300)-100; const cy=80+(i%3)*30;
        ctx.beginPath(); ctx.ellipse(cx,cy,60,24,0,0,Math.PI*2);
        ctx.ellipse(cx+40,cy+6,50,20,0,0,Math.PI*2);
        ctx.ellipse(cx-40,cy+10,40,18,0,0,Math.PI*2); ctx.fill(); } }
    function rocks(off,y,color){ ctx.fillStyle=color; const k=600; const x1=(-off%(k*2));
      for(let i=-1;i<=3;i++){const bx=x1+i*k; ctx.fillRect(bx+120,y+40,120,120);
        ctx.fillRect(bx+300,y+10,80,150); ctx.fillRect(bx+480,y+30,150,140); } }
    sprite.onload=()=>init();
  </script>
</body>
</html>
